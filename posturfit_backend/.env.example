# Environment variables for PostureFit Backend
# Copy this file to .env and fill in your actual values

# --- Database ---
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/posturfit

# --- JWT Authentication ---
JWT_SECRET_KEY=POSTURFIT_SECRET_KEY_SUPER_SAFE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
