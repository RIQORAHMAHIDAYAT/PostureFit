# Environment variables for PostureFit Backend
# Salin file ini ke .env dan isi dengan nilai asli sebelum menjalankan server.
# SEMUA variabel wajib diisi — server akan gagal start jika ada yang kosong.

# --- Database ---
DATABASE_URL=mysql+pymysql://root:PASSWORD@127.0.0.1:3306/posturfit

# --- JWT Authentication ---
# Ganti dengan string acak yang panjang dan kuat (min. 32 karakter)
JWT_SECRET_KEY=ganti-dengan-secret-key-yang-kuat-dan-panjang
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Session Admin Dashboard ---
# Ganti dengan string acak yang berbeda dari JWT_SECRET_KEY
SESSION_SECRET=ganti-dengan-session-secret-yang-kuat

# --- MongoDB Atlas (Sync Edukasi) ---
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- OTP Email (SMTP Gmail) ---
# Aktifkan 2FA di Google Account, lalu buat App Password di:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailmu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
OTP_EXPIRE_MINUTES=1

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
